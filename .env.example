# ── Writent Configuration ──────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Required: Your OpenCode API key (or any OpenAI-compatible API)
OPENCODE_API_KEY=sk-your-api-key-here

# Optional: API endpoint (default works with OpenCode)
# OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1

# Optional: Models (defaults shown)
# OPENCODE_MODEL=mimo-v2.5
# OPENCODE_FALLBACK_MODEL=deepseek-v4-flash

# Optional: Database (default: SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./writent.db

# Optional: Research tuning
# MAX_RESEARCH_AGENTS=3
# BROWSER_TIMEOUT_MS=30000
# MAX_BROWSER_CONTEXTS=5
